{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "rootDir": "prisma",
    "outDir": "dist"
  },
  "include": ["prisma/**/*.ts"],
  "exclude": ["node_modules"]
}
