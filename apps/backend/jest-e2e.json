{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "setupFiles": ["<rootDir>/src/presentation/pledge/e2e-env.ts"],
  "testMatch": ["**/*.e2e-spec.ts"],
  "moduleFileExtensions": ["js", "json", "ts"],
  "transform": {
    "^.+\\.(ts|tsx)$": ["ts-jest", { "tsconfig": "tsconfig.e2e.json" }]
  }
}
