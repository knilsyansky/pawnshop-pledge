generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PledgeStatus {
  ACTIVE
  REDEEMED
}

model Client {
  id       Int      @id @default(autoincrement())
  fullName String
  phone    String   @unique
  pledges  Pledge[]
}

model Tariff {
  id              Int      @id @default(autoincrement())
  name            String
  basePeriodDays  Int
  basePeriodRate  Decimal  @db.Decimal(10, 2)
  overdueRate     Decimal  @db.Decimal(10, 2)
  pledges         Pledge[]
}

model ItemCategory {
  id            Int          @id @default(autoincrement())
  name          String
  specification Json
  pledgeItems   PledgeItem[]
}

model Pledge {
  id             Int            @id @default(autoincrement())
  tariff         Tariff         @relation(fields: [tariffId], references: [id])
  tariffId       Int
  client         Client         @relation(fields: [clientId], references: [id])
  clientId       Int
  createdAt      DateTime       @default(now())
  dueDate        DateTime
  amount         Decimal        @db.Decimal(12, 2)
  redeemedAmount Decimal?       @db.Decimal(12, 2)
  redeemedAt     DateTime?
  status         PledgeStatus   @default(ACTIVE)
  items          PledgeItem[]
}

model PledgeItem {
  id             Int      @id @default(autoincrement())
  pledge         Pledge   @relation(fields: [pledgeId], references: [id])
  pledgeId       Int
  category       ItemCategory @relation(fields: [categoryId], references: [id])
  categoryId     Int
  name           String
  estimatedValue Decimal  @db.Decimal(12, 2)
  specifications Json
}
